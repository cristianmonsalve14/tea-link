enum grado_discapacidad_enum {
  NO_CALIFICADO
  SIN_DISCAPACIDAD
  LEVE
  MODERADA
  SEVERA
  PROFUNDA
}

model Perfil {
  id                         Int                         @id @default(autoincrement())
  rut                        String?                     @unique @db.VarChar(12)
  nombre                     String                      @db.VarChar(255)
  edad                       Int?
  nivel_educacional          nivel_educacional_enum?
  diagnostico_clinico        diagnostico_clinico_enum
  diagnostico_secundario     diagnostico_clinico_enum?
  causa_discapacidad         causa_discapacidad_enum?
  grado_discapacidad         grado_discapacidad_enum     @default(NO_CALIFICADO)
  porcentaje_rnd             Int?
  tiene_credencial_rnd       Boolean                     @default(false)
  fecha_nacimiento           DateTime?                   @db.Date
  notas                      String?
  consentimiento_estado      consentimiento_estado_enum  @default(PENDIENTE)
  consentimiento_sujeto      consentimiento_sujeto_enum  @default(TUTOR_LEGAL)
  consentimiento_aceptado_at DateTime?                   @db.Timestamp(6)
  consentimiento_version     String?                     @db.VarChar(20)
  consentimiento_por_usuario_id Int?
  consentimiento_por         Usuario?                    @relation("PerfilConsentimientoTutor", fields: [consentimiento_por_usuario_id], references: [id], onUpdate: NoAction, map: "fk_perfil_consentimiento_usuario")
  created_at                 DateTime                    @default(now()) @db.Timestamp(6)
  updated_at                 DateTime                    @default(now()) @updatedAt @db.Timestamp(6)
  institucion_id             Int
  institucion                Institucion                 @relation("InstitucionPerfiles", fields: [institucion_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_perfil_institucion")
  observaciones              Observacion[]
  usuarios                   PerfilUsuario[]
  solicitudes_institucion    SolicitudInstitucionPerfil[]

  @@index([institucion_id], map: "idx_perfil_institucion_id")
  @@index([consentimiento_estado], map: "idx_perfil_consentimiento_estado")
  @@index([institucion_id, nivel_educacional], map: "idx_perfil_institucion_nivel")
  @@index([diagnostico_clinico], map: "idx_perfil_diagnostico_clinico")
  @@index([rut], map: "idx_perfil_rut")
  @@map("perfiles")
}

enum consentimiento_sujeto_enum {
  TUTOR_LEGAL
  TITULAR
}

enum consentimiento_estado_enum {
  PENDIENTE
  ACEPTADO
  RECHAZADO
}

model PerfilUsuario {
  perfil_id                  Int
  usuario_id                 Int
  rol_en_perfil              rol_perfil_enum
  puede_editar               Boolean         @default(false)
  consentimiento_aceptado_at DateTime?       @db.Timestamp(6)
  created_at                 DateTime        @default(now()) @db.Timestamp(6)
  perfil        Perfil          @relation(fields: [perfil_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_perfil_usuario_perfil")
  usuario       Usuario         @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_perfil_usuario_usuario")

  @@id([perfil_id, usuario_id])
  @@index([perfil_id], map: "idx_perfil_usuario_perfil_id")
  @@index([usuario_id], map: "idx_perfil_usuario_usuario_id")
  @@map("perfil_usuario")
}

model Observacion {
  id           Int                        @id @default(autoincrement())
  titulo       String                     @db.VarChar(255)

  descripcion  String
  categoria    categoria_observacion_enum
  fecha_evento DateTime                   @db.Timestamp(6)
  perfil_id    Int
  autor_id     Int
  privacidad   privacidad_observacion_enum @default(PUBLICA)
  created_at   DateTime                   @default(now()) @db.Timestamp(6)
  updated_at   DateTime                   @default(now()) @updatedAt @db.Timestamp(6)
  autor        Usuario                    @relation("AutorObservacion", fields: [autor_id], references: [id], onUpdate: NoAction, map: "fk_observaciones_autor")
  perfil       Perfil                     @relation(fields: [perfil_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_observaciones_perfil")
  reportes     ObservacionEnReporte[]

  @@index([autor_id], map: "idx_observaciones_autor_id")
  @@index([categoria], map: "idx_observaciones_categoria")
  @@index([fecha_evento], map: "idx_observaciones_fecha_evento")
  @@index([perfil_id, fecha_evento(sort: Desc)], map: "idx_observaciones_perfil_fecha")
  @@index([perfil_id], map: "idx_observaciones_perfil_id")
  @@map("observaciones")
}

enum privacidad_observacion_enum {
  PUBLICA
  PRIVADA
  MULTINIVEL
}

model Reporte {
  id            Int                    @id @default(autoincrement())
  titulo        String                 @db.VarChar(255)
  fecha_inicio  DateTime               @db.Date
  fecha_fin     DateTime               @db.Date
  formato       formato_reporte_enum
  url_archivo   String?                @db.VarChar(500)
  creador_id    Int
  created_at    DateTime               @default(now()) @db.Timestamp(6)
  observaciones ObservacionEnReporte[]
  creador       Usuario                @relation(fields: [creador_id], references: [id], onUpdate: NoAction, map: "fk_reportes_creador")

  @@index([creador_id], map: "idx_reportes_creador_id")
  @@index([created_at(sort: Desc)], map: "idx_reportes_created_at")
  @@map("reportes")
}

model ObservacionEnReporte {
  reporte_id     Int
  observacion_id Int
  observacion    Observacion @relation(fields: [observacion_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_observaciones_reportes_observacion")
  reporte        Reporte     @relation(fields: [reporte_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_observaciones_reportes_reporte")

  @@id([reporte_id, observacion_id])
  @@index([observacion_id], map: "idx_obs_reportes_observacion_id")
  @@index([reporte_id], map: "idx_obs_reportes_reporte_id")
  @@map("observaciones_en_reportes")
}

model AuditoriaAdmin {
  id         Int      @id @default(autoincrement())
  admin_id   Int
  accion     String   @db.VarChar(100)
  entidad    String?  @db.VarChar(50)
  entidad_id Int?
  detalles   String?  @db.VarChar(500)
  ip_address String?  @db.VarChar(45)
  created_at DateTime @default(now()) @db.Timestamp(6)
  admin      Usuario  @relation(fields: [admin_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_auditoria_admin")

  @@index([admin_id], map: "idx_auditoria_admin_id")
  @@index([created_at(sort: Desc)], map: "idx_auditoria_created_at")
  @@index([accion], map: "idx_auditoria_accion")
  @@map("auditoria_admin")
}

model AuditoriaObservacion {
  id             Int                          @id @default(autoincrement())
  usuario_id     Int
  observacion_id Int?
  perfil_id      Int?
  reporte_id     Int?
  accion         String                       @db.VarChar(80)
  privacidad     privacidad_observacion_enum?
  detalles       String?                      @db.VarChar(500)
  ip_address     String?                      @db.VarChar(45)
  created_at     DateTime                     @default(now()) @db.Timestamp(6)
  usuario        Usuario                      @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_auditoria_obs_usuario")

  @@index([usuario_id], map: "idx_auditoria_obs_usuario")
  @@index([observacion_id], map: "idx_auditoria_obs_observacion")
  @@index([perfil_id], map: "idx_auditoria_obs_perfil")
  @@index([created_at(sort: Desc)], map: "idx_auditoria_obs_created_at")
  @@index([accion], map: "idx_auditoria_obs_accion")
  @@index([privacidad], map: "idx_auditoria_obs_privacidad")
  @@map("auditoria_observacion")
}

enum categoria_observacion_enum {
  CONDUCTA
  COMUNICACION
  SOCIAL
  ACADEMICO
  SENSORIAL
  MOTOR
  CLINICO
  OTRO
}

enum formato_reporte_enum {
  PDF
  EXCEL
}

enum rol_enum {
  FAMILIA
  EDUCADOR
  PROFESIONAL
  ADMINISTRADOR
  MEDICO
  SUPERADMIN
}

enum rol_perfil_enum {
  TUTOR
  TITULAR
  EDUCADOR
  PROFESIONAL
  MEDICO
}

enum solicitud_institucion_estado_enum {
  PENDIENTE
  ACEPTADA
  RECHAZADA
}

model SolicitudInstitucionPerfil {
  id                         Int                              @id @default(autoincrement())
  perfil_id                  Int
  institucion_solicitante_id Int
  institucion_invitada_id    Int
  estado                     solicitud_institucion_estado_enum @default(PENDIENTE)
  solicitado_por_id          Int
  respondido_por_id          Int?
  respondido_at              DateTime?                        @db.Timestamp(6)
  created_at                 DateTime                         @default(now()) @db.Timestamp(6)
  perfil                     Perfil                           @relation(fields: [perfil_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_solicitud_perfil")
  institucion_solicitante    Institucion                      @relation("SolicitudInstOrigen", fields: [institucion_solicitante_id], references: [id], onUpdate: NoAction, map: "fk_solicitud_inst_origen")
  institucion_invitada       Institucion                      @relation("SolicitudInstDestino", fields: [institucion_invitada_id], references: [id], onUpdate: NoAction, map: "fk_solicitud_inst_destino")
  solicitado_por             Usuario                          @relation("SolicitudEnviadaPor", fields: [solicitado_por_id], references: [id], onUpdate: NoAction, map: "fk_solicitud_solicitado_por")
  respondido_por             Usuario?                         @relation("SolicitudRespondidaPor", fields: [respondido_por_id], references: [id], onUpdate: NoAction, map: "fk_solicitud_respondido_por")

  @@unique([perfil_id, institucion_invitada_id], map: "uq_solicitud_perfil_inst_invitada")
  @@index([institucion_invitada_id, estado], map: "idx_solicitud_inst_invitada_estado")
  @@map("solicitudes_institucion_perfil")
}
