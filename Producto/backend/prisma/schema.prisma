model Institucion {
  id               Int                   @id @default(autoincrement())
  nombre           String                @db.VarChar(255)
  tipo             tipo_institucion_enum
  region           region_chile_enum?
  comuna           String?               @db.VarChar(100)
  localidad        String?               @db.VarChar(120)
  direccion        String?               @db.VarChar(255)
  email_contacto   String?               @db.VarChar(255)
  telefono_contacto String?              @db.VarChar(50)
  registro_manual  Boolean               @default(true)
  catalogo_establecimiento_id Int?       @unique
  codigo_externo   String?               @db.VarChar(32)
  catalogo_fuente  catalogo_fuente_enum?
  tipo_oficial     String?               @db.VarChar(120)
  dependencia_oficial String?            @db.VarChar(80)
  created_at       DateTime              @default(now()) @db.Timestamp(6)
  updated_at       DateTime              @default(now()) @updatedAt @db.Timestamp(6)
  catalogo_establecimiento CatalogoEstablecimiento? @relation(fields: [catalogo_establecimiento_id], references: [id], onDelete: SetNull)
  usuarios   Usuario[]            @relation("InstitucionUsuarios")
  perfiles   Perfil[]             @relation("InstitucionPerfiles")
  solicitudes_enviadas    SolicitudInstitucionPerfil[] @relation("SolicitudInstOrigen")
  solicitudes_recibidas   SolicitudInstitucionPerfil[] @relation("SolicitudInstDestino")

  @@index([region], map: "idx_institucion_region")
  @@index([comuna], map: "idx_institucion_comuna")
  @@index([catalogo_fuente, codigo_externo], map: "idx_institucion_catalogo_codigo")
  @@map("instituciones")
}

model CatalogoEstablecimiento {
  id                  Int                   @id @default(autoincrement())
  fuente              catalogo_fuente_enum
  ambito              catalogo_ambito_enum
  codigo_externo      String                @db.VarChar(32)
  nombre              String                @db.VarChar(255)
  nombre_busqueda     String                @db.VarChar(255)
  tipo_oficial        String?               @db.VarChar(120)
  region              region_chile_enum?
  comuna              String?               @db.VarChar(100)
  localidad           String?               @db.VarChar(120)
  direccion           String?               @db.VarChar(255)
  dependencia         String?               @db.VarChar(80)
  sostenedor          String?               @db.VarChar(255)
  tiene_pie           Boolean               @default(false)
  es_escuela_especial Boolean               @default(false)
  vigente             Boolean               @default(true)
  metadata            Json?
  institucion         Institucion?

  @@unique([fuente, codigo_externo], map: "uq_catalogo_fuente_codigo")
  @@index([ambito], map: "idx_catalogo_ambito")
  @@index([region, comuna], map: "idx_catalogo_region_comuna")
  @@index([nombre_busqueda], map: "idx_catalogo_nombre_busqueda")
  @@index([tipo_oficial], map: "idx_catalogo_tipo_oficial")
  @@map("catalogo_establecimientos")
}

enum catalogo_fuente_enum {
  MINEDUC_ESCOLAR
  DEIS_SALUD
}

enum catalogo_ambito_enum {
  EDUCACION
  SALUD
  TERAPEUTICO
}

enum region_chile_enum {
  ARICA_PARINACOTA
  TARAPACA
  ANTOFAGASTA
  ATACAMA
  COQUIMBO
  VALPARAISO
  METROPOLITANA
  OHIGGINS
  MAULE
  NUBLE
  BIOBIO
  ARAUCANIA
  LOS_RIOS
  LOS_LAGOS
  AYSEN
  MAGALLANES
}

enum tipo_institucion_enum {
  FAMILIA
  CENTRO_EDUCACIONAL
  CENTRO_MEDICO
  CENTRO_PROFESIONAL
  SISTEMA
}
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id              Int              @id @default(autoincrement())
  email           String           @unique @db.VarChar(255)
  password_hash   String           @db.VarChar(255)
  nombre_completo String           @db.VarChar(255)
  rol             rol_enum
  must_change_password Boolean       @default(false)
  consentimiento_aceptado_at DateTime? @db.Timestamp(6)
  consentimiento_version     String?   @db.VarChar(20)
  created_at      DateTime         @default(now()) @db.Timestamp(6)
  updated_at      DateTime         @default(now()) @updatedAt @db.Timestamp(6)
  observaciones   Observacion[]    @relation("AutorObservacion")
  perfiles        PerfilUsuario[]
  reportes        Reporte[]
  acciones_admin  AuditoriaAdmin[]
  acciones_observacion AuditoriaObservacion[]
  consentimientos_perfil Perfil[] @relation("PerfilConsentimientoTutor")
  solicitudes_institucion_enviadas SolicitudInstitucionPerfil[] @relation("SolicitudEnviadaPor")
  solicitudes_institucion_respondidas SolicitudInstitucionPerfil[] @relation("SolicitudRespondidaPor")
  institucion_id  Int?
  institucion     Institucion?     @relation("InstitucionUsuarios", fields: [institucion_id], references: [id])
  niveles_educacionales nivel_educacional_enum[] @default([])
  especialidad    especialidad_educador_enum?

  @@index([email], map: "idx_usuarios_email")
  @@map("usuarios")
}

enum nivel_educacional_enum {
  PARVULARIA_NT1
  PARVULARIA_NT2
  BASICO_1
  BASICO_2
  BASICO_3
  BASICO_4
  BASICO_5
  BASICO_6
  BASICO_7
  BASICO_8
  MEDIO_1
  MEDIO_2
  MEDIO_3
  MEDIO_4
  ESPECIAL_TRANSICION
  LABORAL
  FORMACION_TECNICA
  UNIVERSITARIO
}

enum especialidad_educador_enum {
  DOCENTE_TITULAR
  PROFESOR_JEFE
  EDUCADOR_PARVULARIA
  EDUCADOR_DIFERENCIAL
  EDUCADOR_AULA_INTEGRADA
  COORDINADOR_PIE
  PSICOPEDAGOGO
  ASISTENTE_AULA
  ORIENTADOR
  FONOAUDIOLOGO
  KINESIOLOGO
  TERAPEUTA_OCUPACIONAL
  PSICOLOGO
  NEUROPSICOLOGO
  MUSICOTERAPEUTA
  TRABAJADOR_SOCIAL
  NUTRICIONISTA
  TERAPEUTA_ABA
  COORDINADOR_TERAPEUTICO
  INTERVENCION_TEMPRANA
}

enum diagnostico_clinico_enum {
  TEA
  TDAH
  TEL
  DISCAPACIDAD_INTELECTUAL
  SINDROME_DOWN
  PARALISIS_CEREBRAL
  DISCAPACIDAD_VISUAL
  DISCAPACIDAD_AUDITIVA
  EPILEPSIA
  SINDROME_FRAGIL_X
  RETRASO_GLOBAL_DESARROLLO
  TRASTORNO_APRENDIZAJE
